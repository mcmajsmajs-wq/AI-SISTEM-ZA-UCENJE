{
  "$schema": "https://opencode.ai/config.json",
  "mcpServers": {
    "brave-search": {
      "command": "npx",
      "args": ["-y", "mcp-server-brave-search"]
    },
    "docker": {
      "command": "docker-mcp"
    },
    "firecrawl": {
      "command": "firecrawl-mcp"
    },
    "playwright": {
      "command": "playwright-mcp"
    },
    "sequential-thinking": {
      "command": "mcp-server-sequential-thinking"
    },
    "markdownify": {
      "command": "mcp-markdownify-server"
    }
  },
  "permission": {
    "bash": {
      "*": "ask"
    },
    "edit": "ask"
  }
}
