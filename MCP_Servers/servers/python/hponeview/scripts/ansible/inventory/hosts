# Ansible Inventory for OneView Servers
# This inventory defines OneView servers for automation

[oneview_servers]
# Add your OneView servers here
# Example:
# server1.local ansible_host=10.0.1.100
# server2.local ansible_host=10.0.1.101
# server3.local ansible_host=10.0.1.102

[oneview_appliances]
# OneView management appliances
oneview.local ansible_host=10.0.1.20

[all:vars]
# OneView connection settings
oneview_hostname=oneview.local
oneview_username=Administrator
oneview_password= "{{ vault_oneview_password }}"
oneview_api_version=3000

# Execution settings
ansible_connection=local
ansible_python_interpreter=/usr/bin/python3

# Security settings
ansible_ssh_common_args='-o StrictHostKeyChecking=no'
ansible_ssh_pipelining=True

# Logging
ansible_log_path=/var/log/ansible
ansible_log_folder=ansible

# Timeout settings
ansible_timeout=30
ansible_command_timeout=30
ansible_connect_timeout=30

# Retry settings
ansible_retries=3
ansible_retry_delay=5

# Output formatting
ansible_stdout_callback=debug
ansible_stderr_callback=debug

# Fact gathering
ansible_gathering=gather_facts
ansible_gather_subset=all
ansible_gather_timeout=30

# Error handling
ansible_error_on_missing_vars=True
ansible_any_errors_fatal=False

# Check mode (for testing)
ansible_check_mode=False

# Diff mode (for debugging)
ansible_diff_mode=False

# Verbosity
ansible_verbosity=0

# Host key checking
ansible_host_key_checking=False

# Pipelining
ansible_pipelining=True

# Private key variables
ansible_ssh_private_key_file=~/.ssh/id_rsa

# SSH config
ansible_ssh_config_file=~/.ssh/config

# SSH transfer method
ansible_ssh_transfer_method=sftp

# SSH scp if ssh
ansible_ssh_scp_if_ssh=True

# SSH exec arguments
ansible_ssh_exec_args=-o ControlMaster=auto -o ControlPersist=60s

# SSH arguments
ansible_ssh_args=-o ControlMaster=auto -o ControlPersist=60s

# SSH extra args
ansible_ssh_extra_args=-o StrictHostKeyChecking=no

# SSH common auth
ansible_ssh_common_auth=no

# SSH pipelining
ansible_ssh_pipelining=True

# SSH scp if sftp
ansible_ssh_scp_if_sftp=False

# SSH transfer method
ansible_ssh_transfer_method=sftp

# SSH use agent
ansible_ssh_use_agent=True

# SSH allow world readable temp files
ansible_ssh_allow_world_readable_tmpfiles=False

# SSH control path
ansible_ssh_control_path_dir=~/.ansible/cp

# SSH control path dir permissions
ansible_ssh_control_path_dir_permissions=0700

# SSH control path
ansible_ssh_control_path=~/.ansible/cp/%%h

# SSH control path dir
ansible_ssh_control_path_dir=~/.ansible/cp