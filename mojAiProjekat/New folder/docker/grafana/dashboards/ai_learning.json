{
  "__inputs": [],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "AI Sistem za učenje — overview: API, Celery, DB, learning activity",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{method}} {{status_code}} {{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "HTTP Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_total{status_code=~'4..|5..'}[5m]) / rate(http_requests_total[5m]) * 100",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 3,
      "title": "API Latency P95 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95 latency",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 4,
      "title": "Celery Active Tasks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "celery_workers_active",
          "legendFormat": "Active Tasks",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "blue", "mode": "fixed" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background" }
    },
    {
      "id": 5,
      "title": "Celery Task Queue Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "celery_queue_length",
          "legendFormat": "Queue",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "orange", "mode": "fixed" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background" }
    },
    {
      "id": 6,
      "title": "DB Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sqlalchemy_pool_checkedout",
          "legendFormat": "Checked Out",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "sqlalchemy_pool_size",
          "legendFormat": "Pool Size",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 7,
      "title": "Quiz Generation Duration (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.5, rate(celery_task_duration_seconds_bucket{task_name='generate_quiz_task'}[10m]))",
          "legendFormat": "p50 duration",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(celery_task_duration_seconds_bucket{task_name='generate_quiz_task'}[10m]))",
          "legendFormat": "p95 duration",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 8,
      "title": "Total Registered Users",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "ai_learning_users_total",
          "legendFormat": "Users",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "green", "mode": "fixed" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background" }
    },
    {
      "id": 9,
      "title": "Total Quizzes Generated",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 24 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "ai_learning_quizzes_total",
          "legendFormat": "Quizzes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "purple", "mode": "fixed" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background" }
    },
    {
      "id": 10,
      "title": "Documents Processed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 24 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "ai_learning_documents_total",
          "legendFormat": "Documents",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "teal", "mode": "fixed" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background" }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ai-learning", "backend", "celery"],
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AI Sistem za učenje — Overview",
  "uid": "ai-learning-overview",
  "version": 1
}
