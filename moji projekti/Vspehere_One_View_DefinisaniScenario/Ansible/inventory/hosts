# Ansible Inventory za VMware i HP OneView Infrastrukturu
# Ovaj fajl definise sve hostove i grupe za automatizaciju

[vmware_infrastructure]
vcenter.local ansible_host=10.0.1.10
esxi01.local ansible_host=10.0.1.11
esxi02.local ansible_host=10.0.1.12
esxi03.local ansible_host=10.0.1.13

[oneview_infrastructure]
oneview.local ansible_host=10.0.1.20

[vmware_hosts]
esxi01.local
esxi02.local
esxi03.local

[vmware_clusters]
production_cluster

[production_cluster]
esxi01.local
esxi02.local
esxi03.local

[vmware:children]
vmware_infrastructure
vmware_hosts

[oneview:children]
oneview_infrastructure

[all:vars]
ansible_user=administrator
ansible_password=vault_required
ansible_connection=local

# VMware Specific Variables
[vmware_infrastructure:vars]
vcenter_server=vcenter.local
vcenter_username=administrator@vsphere.local
vcenter_password=vault_required
vcenter_port=443
vcenter_validate_certs=false

# HP OneView Specific Variables
[oneview_infrastructure:vars]
oneview_server=oneview.local
oneview_username=Administrator
oneview_password=vault_required
oneview_api_version=4000
oneview_validate_certs=false

# Execution Mode (simulate, test, production)
execution_mode=simulate

# Backup Configuration
[all:vars]
backup_check_only=true
backup_host_path="/backups/hosts"
backup_vcenter_path="/backups/vcenter"
backup_retention_days=30

# Patching Configuration
[vmware_hosts:vars]
baseline_name="Critical Patches"
maintenance_mode_timeout=600
remediation_timeout=1800

# Reporting
report_path="/reports/ansible"
log_path="/logs/ansible"
