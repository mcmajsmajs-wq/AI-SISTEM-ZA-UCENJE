# ================================================================================
# ENVIRONMENT VARIABLES - AI LEARNING SYSTEM
# ================================================================================
# Kopirati ovaj fajl u .env i popuniti vrednostima
# NIKADA ne commit-ovati .env fajl u git!
# ================================================================================

# ================================================================================
# APLIKACIJA
# ================================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=json

# ================================================================================
# SECURITY
# ================================================================================
# Generisati jake ključe: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ================================================================================
# DATABASE (PostgreSQL)
# ================================================================================
POSTGRES_USER=ai_learning_user
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=ai_learning_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Full URL format (koristi se u aplikaciji)
DATABASE_URL=postgresql://ai_learning_user:your-secure-password-here@db:5432/ai_learning_db

# ================================================================================
# REDIS
# ================================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ================================================================================
# STORAGE (Lokalni filesystem - default)
# ================================================================================
# Folder za upload fajlove unutar Docker kontejnera
UPLOAD_FOLDER=/app/uploads

# ================================================================================
# CLOUD STORAGE (Opcionalno - S3 Compatible)
# ================================================================================
# Odkomentarisati za cloud storage (AWS S3, MinIO, DigitalOcean Spaces, itd.)
# CLOUD_STORAGE_ENDPOINT=
# CLOUD_STORAGE_ACCESS_KEY=
# CLOUD_STORAGE_SECRET_KEY=
# CLOUD_STORAGE_BUCKET_NAME=ai-learning-uploads
# CLOUD_STORAGE_USE_SSL=true

# ================================================================================
# AI / LLM
# ================================================================================
# Ollama (Local)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT=300

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TIMEOUT=60

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-3-sonnet-20240229
CLAUDE_TIMEOUT=60

# Google (Gemini)
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-1.5-pro

# Groq
GROQ_API_KEY=your-groq-api-key-here

# Mistral
MISTRAL_API_KEY=your-mistral-api-key-here

# DeepL (Prevod)
DEEPL_API_KEY=your-deepl-api-key-here

# ================================================================================
# EMAIL (Za notifikacije)
# ================================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true
EMAIL_FROM=noreply@ai-learning.com

# ================================================================================
# MONITORING
# ================================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_RETENTION=720h

# ================================================================================
# FILE UPLOAD
# ================================================================================
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=pdf
UPLOAD_FOLDER=/app/uploads

# ================================================================================
# CORS
# ================================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ================================================================================
# RATE LIMITING
# ================================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ================================================================================
# BACKUP
# ================================================================================
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

# ================================================================================
# CLAUDE / ANTHROPIC AI
# ================================================================================
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-sonnet-20240229
CLAUDE_TIMEOUT=60

# ================================================================================
# EMAIL / SMTP (za podsetnike i nedeljne sažetke)
# Primer za Gmail: koristite App Password (ne lozinku naloga)
# ================================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=vas-email@gmail.com
# SMTP_PASSWORD=vas-app-password
# SMTP_TLS=true
# EMAIL_FROM=noreply@ai-learning.com
